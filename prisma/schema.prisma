// Neon: use pooled DATABASE_URL only (Vercel has no DIRECT_URL).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  author    String
  createdAt DateTime @default(now())
}

model Feeling {
  id        String   @id @default(cuid())
  content   String
  author    String
  createdAt DateTime @default(now())
}

model BucketItem {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  author    String
  createdAt DateTime @default(now())
}

model SpecialDate {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  note      String?
  author    String?
  createdAt DateTime @default(now())
}

model MissMessage {
  id        String   @id @default(cuid())
  text      String
  author    String
  createdAt DateTime @default(now())
}
