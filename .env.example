# Postgres — Neon pooled URL in production (from Neon dashboard)
# Local: docker compose up -d, then use the default below
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/couple?schema=public"

# Shared login password for Arjun & Soumya
COUPLE_SECRET="your-shared-secret"

# Random long string for signing session cookies
SESSION_SECRET="replace-with-a-long-random-string"

# Vercel Blob — only needed in production on Vercel (auto-set when you enable Blob in the project)
# Local dev: leave empty; photos save to public/uploads/
BLOB_READ_WRITE_TOKEN=""
